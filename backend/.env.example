# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3579
VAULT_SECRET=change-this-to-a-long-random-string-min-32-chars

# ── Network / TLS ─────────────────────────────────────────────────────────────
# If you get "Connection error" or "Cannot reach Anthropic API":
#
# Option A — Corporate network / SSL inspection / managed Mac (most common fix):
# NODE_TLS_REJECT_UNAUTHORIZED=0
#
# Option B — Behind a proxy:
# HTTPS_PROXY=http://127.0.0.1:8080
#
# After adding either option, restart the backend: cd backend && npm run dev
# Verify it works: curl http://localhost:3579/api/health/anthropic

# ── GitHub CI integration (all configurable in UI — .env is optional) ─────────
# GITHUB_TOKEN=ghp_...
# GITHUB_WEBHOOK_SECRET=your-webhook-secret
# ATP_BASE_URL=https://your-public-url
